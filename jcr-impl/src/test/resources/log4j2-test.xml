<?xml version="1.0" encoding="UTF-8"?>
<Configuration>

  <Appenders>
    <Console name="STDOUT" target="SYSTEM_OUT">
      <PatternLayout pattern="%d{HH:mm:ss,SSS} [%t] %highlight{%p} %c{-2} %m%n"/>
    </Console>
  </Appenders>

  <Loggers>
    <Logger name="org.apache.jackrabbit" level="warn"/>
    <Root level="trace">
      <AppenderRef ref="STDOUT"/>
    </Root>
  </Loggers>

</Configuration>
